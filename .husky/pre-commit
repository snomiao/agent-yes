#!/usr/bin/env sh
set -e
bun run fmt
git add -u
bunx lint-staged
bun run build
bun run test:coverage

# Rust validation (only when rs/ files are staged) — gives local feedback
# before CI does. cargo check is fast (~5-15s incremental, type/borrow only,
# no codegen); -D warnings catches new dead code that the cleanup pass tried
# to eliminate. cargo fmt --check enforces consistent formatting.
RS_STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^rs/' || true)
if [ -n "$RS_STAGED" ]; then
  echo "[pre-commit] rs/ changed — running cargo fmt --check + cargo check"
  (cd rs && cargo fmt --all --check)
  (cd rs && RUSTFLAGS="-D warnings" cargo check --workspace --all-targets)
fi

# Rust coverage (only if cargo-tarpaulin is installed)
if command -v cargo-tarpaulin >/dev/null 2>&1; then
  (cd rs && cargo tarpaulin --config tarpaulin.toml --skip-clean --fail-under 90)
fi
